# Podman Image Configuration for an Ubuntu Server

# VERBOSE
#   Set the bash library to verbose logging level
#   Enabled: 1
#   Default: 0
VERBOSE=0

# IMAGE_NAME
#   The base image name (without tag) for the Podman image.
#   Default: ubuntu-server
IMAGE_NAME=ubuntu-server

# IMAGE_VERSION
#   The version/tag to apply to the built image.
#   Default: 24.04
IMAGE_VERSION=24.04

# Container Runtime Configuration

# CONTAINER_MOUNT_DIR
#   Target directory inside the container where the host's shared directory
#   will be mounted. Used by execute_podman_command.
#   Default: /shared
CONTAINER_MOUNT_DIR=/shared

# CONTAINER_LOCALE
#   Locale setting to pass into the container environment.
#   Default: en_US.UTF-8
CONTAINER_LOCALE=en_US.UTF-8
